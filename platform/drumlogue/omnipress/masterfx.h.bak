#pragma once
/*
 * File: masterfx.h
 *
 * OmniPress Master Compressor Effect
 * Based on Empirical Labs Distressor & Eventide Omnipressor
 *
 */

#include <atomic>
#include <cstddef>
#include <cstdint>
#include <cmath>

#include <arm_neon.h>

#include "unit.h"  // Note: Include common definitions for all units

class MasterFX {
 public:
  /*===========================================================================*/
  /* Lifecycle Methods. */
  /*===========================================================================*/

  MasterFX(void) {}
  virtual ~MasterFX(void) {}

  inline int8_t Init(const unit_runtime_desc_t * desc) {
    // Check compatibility of samplerate with unit, for drumlogue should be 48000
    if (desc->samplerate != 48000)
      return k_unit_err_samplerate;

    // Check compatibility of frame geometry
    // Note: input format: [ main_left, main_right, sidechain_left, sidechain_right ]
    // Note: Sidechain feature may unfortunately get removed before official release, in which case
    //       there will be only 2 input channels
    if (desc->input_channels != 4 || desc->output_channels != 2)
      return k_unit_err_geometry;

    samplerate_ = desc->samplerate;
    
    // Initialize state
    Reset();

    return k_unit_err_none;
  }

  inline void Teardown() {}

  inline void Reset() {
    env_state_ = 0.0f;
    sc_hpf_state_ = 0.0f;
    current_gain_ = 1.0f;
    
    // Set default parameter values matching header.c
    setParameter(0, -200); // Thresh
    setParameter(1, 40);   // Ratio
    setParameter(2, 150);  // Attack
    setParameter(3, 200);  // Release
    setParameter(4, 0);    // Makeup
    setParameter(5, 0);    // Drive
    setParameter(6, 100);  // Mix
    setParameter(7, 20);   // SC HPF
  }

  inline void Resume() {}
  inline void Suspend() {}

  /*===========================================================================*/
  /* DSP Process Loop. */
  /*===========================================================================*/

  fast_inline void Process(const float * in, float * out, size_t frames) {
    const float * __restrict in_p = in;
    float * __restrict out_p = out;
    const float * out_e = out_p + (frames << 1);  // assuming stereo output

    // Convert makeup gain from dB to linear
    const float makeup_lin = std::pow(10.0f, makeup_db_ / 20.0f);

    for (; out_p != out_e; in_p += 4, out_p += 2) {
      // Load 4 channels using NEON (Main L, Main R, SC L, SC R)
      float32x4_t sig = vld1q_f32(in_p);
      
      // Extract main stereo channels (low half of the 128-bit vector)
      float32x2_t main_in = vget_low_f32(sig);
      
      // Extract sidechain stereo channels (high half of the 128-bit vector)
      float32x2_t sc_in = vget_high_f32(sig);
      
      // --- 1. Sidechain & Envelope Detection ---
      // TODO: Apply sc_hpf_hz_ filter to sc_in.
      // TODO: Compute mono sidechain level (e.g., max of L/R or sum).
      // TODO: Smooth envelope using attack_ms_ and release_ms_ coefficients.
      
      // --- 2. Gain Computer ---
      // TODO: Convert smoothed envelope to dB.
      // TODO: Compute gain reduction based on thresh_db_ and ratio_.
      // TODO: Convert gain reduction back to linear.
      
      // --- 3. VCA & Overdrive (Character) ---
      // Apply computed gain reduction to main_in.
      // TODO: Apply hyperbolic tangent or polynomial wavefolder based on drive_.
      
      // --- 4. Mix & Makeup ---
      // TODO: Blend processed signal with dry main_in using mix_.
      // TODO: Apply makeup_lin gain.
      
      // Write processed stereo signal to output
      vst1_f32(out_p, main_in);
    }
  }

  /*===========================================================================*/
  /* Parameter Handling. */
  /*===========================================================================*/

  inline void setParameter(uint8_t index, int32_t value) {
    raw_params_[index] = value;
    
    switch (index) {
      case 0: // THRESH (-60.0 to 0.0 dB, 1 decimal)
        thresh_db_ = value * 0.1f;
        break;
      case 1: // RATIO (1.0 to 20.0, 1 decimal)
        ratio_ = value * 0.1f;
        break;
      case 2: // ATTACK (0.1 to 100.0 ms, 1 decimal)
        attack_ms_ = value * 0.1f;
        break;
      case 3: // RELEASE (10 to 2000 ms, 0 decimals)
        release_ms_ = static_cast<float>(value);
        break;
      case 4: // MAKEUP (0.0 to 24.0 dB, 1 decimal)
        makeup_db_ = value * 0.1f;
        break;
      case 5: // DRIVE (0 to 100%, 0 decimals)
        drive_ = value * 0.01f; // store as 0.0 to 1.0
        break;
      case 6: // MIX (-100 to +100)
        mix_ = (value + 100.0f) * 0.005f; // Map -100..100 to 0.0..1.0
        break;
      case 7: // SC HPF (20 to 500 Hz, 0 decimals)
        sc_hpf_hz_ = static_cast<float>(value);
        break;
      default:
        break;
    }
  }

  inline int32_t getParameterValue(uint8_t index) const {
    if (index < 8) {
      return raw_params_[index];
    }
    return 0;
  }

  inline const char * getParameterStrValue(uint8_t index, int32_t value) const {
    (void)value;
    // Note: Could format string values here if custom display logic is needed.
    return nullptr;
  }

  inline const uint8_t * getParameterBmpValue(uint8_t index, int32_t value) const {
    (void)value;
    return nullptr;
  }

  inline void LoadPreset(uint8_t idx) { (void)idx; }
  inline uint8_t getPresetIndex() const { return 0; }
  static inline const char * getPresetName(uint8_t idx) { return nullptr; }

 private:
  /*===========================================================================*/
  /* Private Member Variables. */
  /*===========================================================================*/

  std::atomic_uint_fast32_t flags_;
  float samplerate_;
  
  // Raw integer values from UI
  int32_t raw_params_[8];

  // Floating-point parameter values
  float thresh_db_;
  float ratio_;
  float attack_ms_;
  float release_ms_;
  float makeup_db_;
  float drive_;
  float mix_;
  float sc_hpf_hz_;

  // DSP State
  float env_state_;
  float sc_hpf_state_;
  float current_gain_;

};